	float: left;
	margin-right: 1em;
}

img:nth-of-type(2) {
	float: left;
	margin-right: 1em;
}
img:nth-of-type(3) {
	float: left;
	margin-right: 1em;
}
img:nth-of-type(4) {
	float: left;
	margin-right: 1em;
